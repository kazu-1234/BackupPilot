<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="BackupPilot.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24" RowSpacing="16" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Text="BackupPilot" FontSize="30" FontWeight="SemiBold" />
            <Button
                x:Name="SettingsButton"
                Grid.Column="1"
                Width="40"
                Height="40"
                Padding="0"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                ToolTipService.ToolTip="設定">
                <FontIcon FontSize="18" Glyph="&#xE713;" />
                <Button.Flyout>
                    <Flyout Placement="BottomEdgeAlignedRight">
                        <StackPanel MinWidth="260" Spacing="14">
                            <TextBlock Text="設定" FontSize="18" FontWeight="SemiBold" />
                            <ComboBox
                                x:Name="ThemeModeComboBox"
                                Header="テーマ"
                                Width="220"
                                SelectionChanged="ThemeModeComboBox_SelectionChanged">
                                <ComboBoxItem Content="システムに合わせる" />
                                <ComboBoxItem Content="ライト" />
                                <ComboBoxItem Content="ダーク" />
                            </ComboBox>
                            <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />
                            <StackPanel Spacing="4">
                                <TextBlock Text="バージョン情報" FontWeight="SemiBold" />
                                <TextBlock x:Name="VersionTextBlock" Text="BackupPilot v1.2.25" Opacity="0.75" />
                            </StackPanel>
                            <Button Content="アップデート確認" Click="CheckUpdateButton_Click" />
                        </StackPanel>
                    </Flyout>
                </Button.Flyout>
            </Button>
        </Grid>

        <Grid Grid.Row="1" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="420" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Padding="16" CornerRadius="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <Grid RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="バックアップ対象" FontSize="18" FontWeight="SemiBold" />

                    <ListView
                        x:Name="JobsListView"
                        Grid.Row="1"
                        SelectionChanged="JobsListView_SelectionChanged">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="MinHeight" Value="72" />
                                <Setter Property="Padding" Value="0" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="2,6" ColumnSpacing="4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Width="32" MinWidth="0" Padding="0" IsChecked="{Binding IsEnabled, Mode=TwoWay}" VerticalAlignment="Center" Checked="JobEnabledCheckBox_Changed" Unchecked="JobEnabledCheckBox_Changed" />
                                    <StackPanel Grid.Column="1" Spacing="2">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding SourcePath}" FontSize="12" Opacity="0.7" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding DestinationPath}" FontSize="12" Opacity="0.7" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8">
                        <Button Content="追加" Click="AddJobButton_Click" />
                        <Button Content="削除" Click="DeleteJobButton_Click" />
                    </StackPanel>
                </Grid>
            </Border>

            <ScrollViewer
                Grid.Column="1"
                HorizontalScrollBarVisibility="Auto"
                VerticalScrollBarVisibility="Auto">
                <Grid RowSpacing="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Padding="16" CornerRadius="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                        <Grid RowSpacing="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="実行設定" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <Button
                                        x:Name="RunButton"
                                        Content="開始"
                                        MinWidth="72"
                                        Style="{ThemeResource AccentButtonStyle}"
                                        Click="RunButton_Click" />
                                    <Button
                                        x:Name="CancelButton"
                                        Content="停止"
                                        MinWidth="72"
                                        IsEnabled="False"
                                        Background="#C42B1C"
                                        Foreground="White"
                                        Click="CancelButton_Click" />
                                </StackPanel>
                            </Grid>
                            <TextBox x:Name="JobNameTextBox" Grid.Row="1" Header="名称" PlaceholderText="空欄の場合はコピー元名を使用" TextChanged="JobTextBox_Changed" />
                            <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="コピー方式" />
                                    <ComboBox x:Name="CopyModeComboBox" Width="108" MinWidth="0" HorizontalAlignment="Left" SelectionChanged="SettingsComboBox_Changed">
                                        <ComboBoxItem Content="差分コピー" />
                                        <ComboBoxItem Content="強制コピー" />
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Spacing="4">
                                    <TextBlock Text="上書き方針" />
                                    <ComboBox
                                        x:Name="OverwriteModeComboBox"
                                        Style="{StaticResource TextFitComboBoxStyle}"
                                        Loaded="OverwriteModeComboBox_Loaded"
                                        SelectionChanged="SettingsComboBox_Changed">
                                        <ComboBoxItem Content="上書きする" />
                                        <ComboBoxItem Content="既存ファイルはスキップ" />
                                    </ComboBox>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8">
                                <Button x:Name="ExportJsonButton" Content="JSON保存" Click="ExportJsonButton_Click" />
                                <Button x:Name="ImportJsonButton" Content="JSON読込" Click="ImportJsonButton_Click" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1" Padding="16" CornerRadius="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                        <Grid RowSpacing="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="コピー元・バックアップ先" FontSize="18" FontWeight="SemiBold" />
                            <Grid Grid.Row="1" ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="SourcePathTextBox" Header="コピー元" TextChanged="JobTextBox_Changed" />
                                <Button Grid.Column="1" Content="フォルダ" Margin="0,28,0,0" Click="BrowseSourceFolderButton_Click" />
                                <Button Grid.Column="2" Content="ファイル" Margin="0,28,0,0" Click="BrowseSourceFileButton_Click" />
                            </Grid>
                            <Grid Grid.Row="2" ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="DestinationPathTextBox" Header="バックアップ先" PlaceholderText="例: D:\Backup" TextChanged="JobTextBox_Changed" />
                                <Button Grid.Column="1" Content="参照" Margin="0,28,0,0" Click="BrowseDestinationButton_Click" />
                            </Grid>
                        </Grid>
                    </Border>

                    <Border Grid.Row="2" Padding="16" CornerRadius="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                        <Grid RowSpacing="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="実行ログ" FontSize="18" FontWeight="SemiBold" />
                                <TextBlock x:Name="SummaryTextBlock" Grid.Column="1" Opacity="0.75" />
                            </Grid>
                            <ProgressBar x:Name="ProgressBar" Grid.Row="1" Minimum="0" Maximum="1" Value="0" />
                            <TextBox
                                x:Name="LogTextBox"
                                Grid.Row="2"
                                MinHeight="220"
                                AcceptsReturn="True"
                                IsReadOnly="True"
                                TextWrapping="NoWrap"
                                FontFamily="Consolas"
                                ScrollViewer.VerticalScrollBarVisibility="Auto"
                                ScrollViewer.HorizontalScrollBarVisibility="Auto" />
                        </Grid>
                    </Border>
                </Grid>
            </ScrollViewer>
        </Grid>

    </Grid>
</Window>
